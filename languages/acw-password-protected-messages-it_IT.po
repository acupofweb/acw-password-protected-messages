#. Plugin Name of the plugin
#: acw-password-protected-messages.php
msgid "ACW Custom Messages for Password Protected Pages"
msgstr "ACW Custom Messages for Password Protected Pages"

#. Author URI of the plugin
#: acw-password-protected-messages.php
msgid "https://www.acupofweb.it/"
msgstr "https://www.acupofweb.it/"

#. Description of the plugin
#: acw-password-protected-messages.php
msgid "Customize the message displayed on password protected content, globally or with a different message for each page or post."
msgstr "Personalizza il messaggio mostrato sui contenuti protetti da password, globalmente o con un messaggio diverso per ogni pagina o articolo."

#. Author of the plugin
#: acw-password-protected-messages.php
msgid "A Cup of Web"
msgstr "A Cup of Web"

#: acw-password-protected-messages.php:129
msgid "This content is password protected. To view it please enter your password below:"
msgstr "Questo contenuto è protetto da password. Per visualizzarlo, inserisci di seguito la tua password:"

#: acw-password-protected-messages.php:134
msgid "Password:"
msgstr "Password:"

#: acw-password-protected-messages.php:145
msgctxt "post password form submit button"
msgid "Enter"
msgstr "Invia"

#: acw-password-protected-messages.php:160
msgid "Settings"
msgstr "Impostazioni"

#: acw-password-protected-messages.php:170
#: acw-password-protected-messages.php:401
msgid "Password Protected Messages"
msgstr "Messaggi contenuti protetti"

#: acw-password-protected-messages.php:171
msgid "Password Messages"
msgstr "Messaggi password"

#: acw-password-protected-messages.php:323
msgid "— Select content —"
msgstr "— Seleziona un contenuto —"

#. translators: %d: post ID.
#: acw-password-protected-messages.php:337
msgid "(no title) #%d"
msgstr "(senza titolo) #%d"

#. translators: %s: post title.
#: acw-password-protected-messages.php:350
msgid "%s (no longer protected)"
msgstr "%s (non più protetto)"

#: acw-password-protected-messages.php:369
msgid "Page or post"
msgstr "Pagina o articolo"

#: acw-password-protected-messages.php:379
msgid "Custom message for this content"
msgstr "Messaggio personalizzato per questo contenuto"

#: acw-password-protected-messages.php:383
msgid "Remove"
msgstr "Rimuovi"

#: acw-password-protected-messages.php:406
msgid "Default message"
msgstr "Messaggio predefinito"

#: acw-password-protected-messages.php:407
msgid "This message replaces the default WordPress text on all password protected content, unless a specific message is set below."
msgstr "Questo messaggio sostituisce il testo predefinito di WordPress su tutti i contenuti protetti da password, a meno che qui sotto non sia impostato un messaggio specifico."

#: acw-password-protected-messages.php:424
msgid "Password field label"
msgstr "Etichetta del campo password"

#: acw-password-protected-messages.php:426
msgid "Password"
msgstr "Password"

#: acw-password-protected-messages.php:428
msgid "Optional. Replaces the \"Password\" label of the input field."
msgstr "Facoltativo. Sostituisce l'etichetta \"Password\" del campo di inserimento."

#: acw-password-protected-messages.php:430
msgid "Wrong password message"
msgstr "Messaggio password errata"

#: acw-password-protected-messages.php:432
msgid "The password you entered is incorrect. Please try again."
msgstr "La password inserita non è corretta. Riprova."

#: acw-password-protected-messages.php:434
msgid "Optional. WordPress shows no feedback when a wrong password is entered: with this message, visitors are told their attempt failed. Leave empty to disable."
msgstr "Facoltativo. WordPress non dà alcun riscontro quando si inserisce una password sbagliata: con questo messaggio i visitatori sapranno che il tentativo non è andato a buon fine. Lascia vuoto per disattivare."

#: acw-password-protected-messages.php:436
msgid "Content-specific messages"
msgstr "Messaggi specifici per contenuto"

#: acw-password-protected-messages.php:437
msgid "Show a different message on specific pages, posts or custom post types. Each one can have its own custom message, which overrides the default message above. Only password protected content is listed."
msgstr "Mostra un messaggio diverso su pagine, articoli o custom post type specifici. Ognuno può avere il proprio messaggio personalizzato, che ha priorità sul messaggio predefinito qui sopra. Sono elencati solo i contenuti protetti da password."

#: acw-password-protected-messages.php:454
msgid "Add another message"
msgstr "Aggiungi un altro messaggio"
