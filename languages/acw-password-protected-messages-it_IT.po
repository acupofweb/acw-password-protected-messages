msgid "ACW Password Protected Messages"
msgstr "ACW Password Protected Messages"

#. Plugin URI of the plugin
#. Author URI of the plugin
#: acw-password-protected-messages.php
msgid "https://www.acupofweb.it/"
msgstr "https://www.acupofweb.it/"

#. Description of the plugin
#: acw-password-protected-messages.php
msgid "Customize the message displayed on password protected content, globally or with a different message for each page."
msgstr "Personalizza il messaggio mostrato sui contenuti protetti da password, globalmente o con un messaggio diverso per ogni pagina."

#. Author of the plugin
#: acw-password-protected-messages.php
msgid "Lorenzo Fracassi"
msgstr "Lorenzo Fracassi"

#: acw-password-protected-messages.php:100
msgid "This content is password protected. To view it please enter your password below:"
msgstr "Questo contenuto è protetto da password. Per visualizzarlo, inserisci di seguito la tua password:"

#: acw-password-protected-messages.php:105
msgid "Password:"
msgstr "Password:"

#: acw-password-protected-messages.php:112
msgctxt "post password form submit button"
msgid "Enter"
msgstr "Invia"

#: acw-password-protected-messages.php:127
msgid "Settings"
msgstr "Impostazioni"

#: acw-password-protected-messages.php:137
#: acw-password-protected-messages.php:280
msgid "Password Protected Messages"
msgstr "Messaggi contenuti protetti"

#: acw-password-protected-messages.php:138
msgid "Password Messages"
msgstr "Messaggi password"

#: acw-password-protected-messages.php:244
msgid "Page"
msgstr "Pagina"

#: acw-password-protected-messages.php:251
msgid "— Select a page —"
msgstr "— Seleziona una pagina —"

#: acw-password-protected-messages.php:258
msgid "Custom message for this page"
msgstr "Messaggio personalizzato per questa pagina"

#: acw-password-protected-messages.php:262
msgid "Remove"
msgstr "Rimuovi"

#: acw-password-protected-messages.php:285
msgid "Default message"
msgstr "Messaggio predefinito"

#: acw-password-protected-messages.php:286
msgid "This message replaces the default WordPress text on all password protected posts and pages, unless a page-specific message is set below."
msgstr "Questo messaggio sostituisce il testo predefinito di WordPress su tutti gli articoli e le pagine protetti da password, a meno che qui sotto non sia impostato un messaggio specifico per la pagina."

#: acw-password-protected-messages.php:303
msgid "Password field label"
msgstr "Etichetta del campo password"

#: acw-password-protected-messages.php:305
msgid "Password"
msgstr "Password"

#: acw-password-protected-messages.php:307
msgid "Optional. Replaces the \"Password\" label of the input field."
msgstr "Facoltativo. Sostituisce l'etichetta \"Password\" del campo di inserimento."

#: acw-password-protected-messages.php:309
msgid "Page-specific messages"
msgstr "Messaggi specifici per pagina"

#: acw-password-protected-messages.php:310
msgid "Show a different message on specific pages. Each page can have its own custom message, which overrides the default message above."
msgstr "Mostra un messaggio diverso su pagine specifiche. Ogni pagina può avere il proprio messaggio personalizzato, che ha priorità sul messaggio predefinito qui sopra."

#: acw-password-protected-messages.php:327
msgid "Add another message"
msgstr "Aggiungi un altro messaggio"
